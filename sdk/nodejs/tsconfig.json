{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "config/index.ts",
        "config/vars.ts",
        "getTwingateConnector.ts",
        "getTwingateConnectors.ts",
        "getTwingateDNSFilteringProfile.ts",
        "getTwingateGateway.ts",
        "getTwingateGroup.ts",
        "getTwingateGroups.ts",
        "getTwingateRemoteNetwork.ts",
        "getTwingateRemoteNetworks.ts",
        "getTwingateResource.ts",
        "getTwingateResources.ts",
        "getTwingateSSHCertificateAuthority.ts",
        "getTwingateSecurityPolicies.ts",
        "getTwingateSecurityPolicy.ts",
        "getTwingateServiceAccounts.ts",
        "getTwingateUser.ts",
        "getTwingateUsers.ts",
        "getTwingateX509CertificateAuthority.ts",
        "index.ts",
        "provider.ts",
        "twingateConnector.ts",
        "twingateConnectorTokens.ts",
        "twingateDNSFilteringProfile.ts",
        "twingateGateway.ts",
        "twingateGatewayConfig.ts",
        "twingateGroup.ts",
        "twingateKubernetesResource.ts",
        "twingateRemoteNetwork.ts",
        "twingateResource.ts",
        "twingateSSHCertificateAuthority.ts",
        "twingateSSHResource.ts",
        "twingateServiceAccount.ts",
        "twingateServiceAccountKey.ts",
        "twingateUser.ts",
        "twingateX509CertificateAuthority.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
